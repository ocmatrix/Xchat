rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['did', 'name', 'status', 'lastSeen', 'updatedAt'])
        && data.did is string && data.did.size() <= 200
        && data.name is string && data.name.size() <= 100
        && (data.avatar == null || (data.avatar is string && data.avatar.size() <= 500))
        && data.status in ['online', 'offline', 'busy']
        && data.lastSeen == request.time
        && data.updatedAt == request.time;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'content', 'protocol', 'nonce', 'timestamp', 'type'])
        && data.senderId == request.auth.uid
        && data.content is string && data.content.size() <= 200000 // 200k limit for secure payloads
        && data.protocol is string && data.protocol.size() <= 50
        && data.nonce is string && data.nonce.size() <= 128
        && data.timestamp == request.time
        && data.type in ['text', 'image', 'file', 'call', 'signal', 'media', 'system'];
    }

    function hasMutualFriendship(uidA, uidB) {
      return exists(/databases/$(database)/documents/users/$(uidA)/friends/$(uidB))
        && exists(/databases/$(database)/documents/users/$(uidB)/friends/$(uidA));
    }

    function isDirectConversationAllowed(conversationData) {
      return conversationData.type != 'direct'
        || (
          conversationData.participants.size() == 2
          && hasMutualFriendship(conversationData.participants[0], conversationData.participants[1])
        );
    }

    // --- Match Groups ---

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // Allow node discovery
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().did == existing().did; // Immutable DID
    }

    // 2. Conversations
    match /conversations/{convId} {
      allow get: if isSignedIn()
        && request.auth.uid in existing().participants
        && isDirectConversationAllowed(existing());
      allow list: if isSignedIn()
        && resource.data.participants.hasAny([request.auth.uid])
        && isDirectConversationAllowed(resource.data);
      
      allow create: if isSignedIn() 
        && incoming().participants.hasAny([request.auth.uid])
        && incoming().participants.size() >= 2
        && isDirectConversationAllowed(incoming());
        
      allow update: if isSignedIn() && request.auth.uid in existing().participants
        && isDirectConversationAllowed(existing())
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['updatedAt', 'lastMessage']);

      // 3. Messages Sub-collection
      match /messages/{msgId} {
        allow list: if isSignedIn() 
          && get(/databases/$(database)/documents/conversations/$(convId)).data.participants.hasAny([request.auth.uid])
          && isDirectConversationAllowed(get(/databases/$(database)/documents/conversations/$(convId)).data);
        
        allow create: if isSignedIn()
          && get(/databases/$(database)/documents/conversations/$(convId)).data.participants.hasAny([request.auth.uid])
          && isDirectConversationAllowed(get(/databases/$(database)/documents/conversations/$(convId)).data)
          && isValidMessage(incoming());
          
        allow delete: if false; // Messages are immutable for audit/protocol reasons unless sharding happens
      }
    }

    // 3.5 Friend Requests & Friend Graph
    match /friend_requests/{requestId} {
      allow create: if isSignedIn()
        && incoming().fromID == request.auth.uid
        && incoming().toID is string
        && incoming().toID != request.auth.uid
        && incoming().status == 'pending';
      allow get, list: if isSignedIn()
        && (resource.data.fromID == request.auth.uid || resource.data.toID == request.auth.uid);
      allow update: if isSignedIn()
        && resource.data.toID == request.auth.uid
        && resource.data.status == 'pending'
        && incoming().status == 'accepted';
    }

    match /users/{userId}/friends/{friendId} {
      allow get, list: if isOwner(userId);
      allow create, update: if isSignedIn() && request.auth.uid in [userId, friendId];
      allow delete: if false;
    }

    // 4. Invites
    match /invites/{code} {
      allow get: if true; // Public check for join
      allow create: if isSignedIn() 
        && incoming().expiresAt > request.time
        && incoming().createdBy == request.auth.uid;
    }

    // 5. System Health
    match /system/ping {
      allow get: if true; // Publicly accessible for health checks
    }
  }
}
