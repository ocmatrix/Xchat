rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny Everything (Strict Backend-Proxy enforced)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    // Kept for documentation, but bypassed in real production deployment
    function isSignedIn() { return request.auth != null; }

    // 1. Friend Requests (Read-only for clients, managed by Backend SA)
    match /friend_requests/{requestId} {
      allow read: if isSignedIn(); // Allow only to read own requests if needed
    }

    // 2. Chat Conversations (Read-only for clients)
    match /conversations/{channelId} {
      allow read: if isSignedIn();
    }
  }
}
